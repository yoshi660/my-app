// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- 学部・学科 ----------
model Faculty {
  id         Int     @id @default(autoincrement())
  name       String // 例: 理工学部
  department String? // 例: システムデザイン工学科

  users   User[]
  courses Course[]

  @@map("faculties")
}

// ---------- ユーザー ----------
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash") // bcrypt でハッシュ化した値
  displayName  String   @map("display_name")
  facultyId    Int?     @map("faculty_id")
  createdAt    DateTime @default(now()) @map("created_at")

  faculty   Faculty?      @relation(fields: [facultyId], references: [id])
  items     Item[] // 出品した商品
  purchases Transaction[] // 購入した取引

  @@map("users")
}

// ---------- 授業 ----------
model Course {
  id        Int     @id @default(autoincrement())
  name      String // 例: 信号処理
  facultyId Int?    @map("faculty_id")
  campus    String? // 日吉 / 矢上 など
  advice    String? // 履修アドバイス

  faculty Faculty? @relation(fields: [facultyId], references: [id])
  items   Item[]

  @@map("courses")
}

// ---------- 商品 ----------
enum ItemType {
  textbook // 教科書
  past_exam // 過去問
  note // ノート
}

enum ItemStatus {
  on_sale // 販売中
  sold // 売切
}

model Item {
  id          Int        @id @default(autoincrement())
  sellerId    Int        @map("seller_id")
  courseId    Int?       @map("course_id")
  title       String
  itemType    ItemType   @map("item_type")
  price       Int
  condition   String? // 'new' | 'good' | 'used' など
  description String?
  status      ItemStatus @default(on_sale)
  createdAt   DateTime   @default(now()) @map("created_at")

  seller      User         @relation(fields: [sellerId], references: [id])
  course      Course?      @relation(fields: [courseId], references: [id])
  transaction Transaction?

  @@map("items")
}

// ---------- 取引 ----------
model Transaction {
  id        Int      @id @default(autoincrement())
  itemId    Int      @unique @map("item_id") // 1商品につき取引は1回
  buyerId   Int      @map("buyer_id")
  createdAt DateTime @default(now()) @map("created_at")

  item  Item @relation(fields: [itemId], references: [id])
  buyer User @relation(fields: [buyerId], references: [id])

  @@map("transactions")
}

